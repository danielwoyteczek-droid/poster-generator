{
  "version": 8,
  "name": "Detail Poster",
  "sources": {
    "maptiler_planet": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key={key}"
    }
  },
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={key}",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#ffffff" }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "landcover",
      "filter": ["in", "class", "grass", "wood", "scrub", "farmland"],
      "paint": {
        "fill-color": "#eef2ec",
        "fill-antialias": false
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "park",
      "paint": {
        "fill-color": "#eaf0e7",
        "fill-antialias": false
      }
    },
    {
      "id": "landuse-urban",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "landuse",
      "filter": ["in", "class", "residential", "industrial", "commercial", "retail"],
      "paint": {
        "fill-color": "#f4f4f0",
        "fill-opacity": {
          "stops": [[6, 0.6], [10, 0.9], [13, 1]]
        }
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "water",
      "filter": ["all", ["==", "$type", "Polygon"], ["!=", "intermittent", 1]],
      "paint": {
        "fill-color": "#b8d4e8",
        "fill-antialias": true
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "waterway",
      "minzoom": 10,
      "paint": {
        "line-color": "#b8d4e8",
        "line-width": {
          "stops": [[10, 0.5], [14, 1.5], [18, 3]]
        }
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": ["in", "class", "minor", "service", "residential", "track", "path"],
      "paint": {
        "line-color": "#e8e8e4",
        "line-width": {
          "stops": [[13, 0.6], [16, 2], [18, 4]]
        }
      }
    },
    {
      "id": "road-major-casing",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["in", "class", "primary", "secondary", "tertiary", "trunk", "motorway"],
      "paint": {
        "line-color": "#d4d4cd",
        "line-width": {
          "stops": [[10, 0.8], [13, 1.5], [16, 4], [18, 8]]
        }
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": ["in", "class", "minor", "service", "residential", "track", "path"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": {
          "stops": [[13, 0.3], [16, 1.2], [18, 3]]
        }
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["in", "class", "primary", "secondary", "tertiary", "trunk", "motorway"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": {
          "stops": [[10, 0.4], [13, 1], [16, 3], [18, 6.5]]
        }
      }
    },
    {
      "id": "railway",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": ["==", "class", "rail"],
      "paint": {
        "line-color": "#c8c8c2",
        "line-width": {
          "stops": [[12, 0.4], [16, 1], [18, 2]]
        }
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#1a1a1a",
        "fill-opacity": 1,
        "fill-antialias": true
      }
    },
    {
      "id": "boundary-admin",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "boundary",
      "minzoom": 4,
      "filter": ["in", "admin_level", 2, 3, 4],
      "paint": {
        "line-color": "#aaaaa5",
        "line-dasharray": [3, 2],
        "line-width": {
          "stops": [[4, 0.5], [10, 1], [16, 1.5]]
        }
      }
    }
  ]
}
