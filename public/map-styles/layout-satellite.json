{
  "version": 8,
  "name": "Satellite Plain",
  "sources": {
    "maptiler_planet": {
      "url": "https://api.maptiler.com/tiles/v4/tiles.json?key={key}",
      "type": "vector"
    },
    "satellite": {
      "url": "https://api.maptiler.com/tiles/satellite-v2/tiles.json?key={key}",
      "type": "raster"
    }
  },
  "layers": [
    {
      "id": "Satellite",
      "type": "raster",
      "source": "satellite",
      "layout": { "visibility": "visible" },
      "paint": { "raster-hue-rotate": 0, "raster-opacity": 1 }
    },
    {
      "id": "Tunnel",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "road",
      "layout": { "line-cap": "butt", "line-join": "miter", "visibility": "none" },
      "paint": {
        "line-color": "hsla(0, 0%, 100%, 0.2)",
        "line-dasharray": [0.28, 0.14],
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 6, 0.5, 20, 30]
      },
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["all", ["match", ["get", "brunnel"], ["tunnel"], true, false], ["any", ["==", ["get", "construction"], false], ["!", ["has", "construction"]]]]]
    },
    {
      "id": "Path",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "pathway",
      "layout": { "line-cap": "square", "line-join": "bevel", "visibility": "none" },
      "paint": {
        "line-color": "hsla(0, 0%, 97%, 0.33)",
        "line-dasharray": [1, 1],
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 14, 0.5, 20, 4]
      },
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["match", ["get", "brunnel"], ["bridge", "ford"], true, ["!", ["has", "brunnel"]]]]
    },
    {
      "id": "Road",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "road",
      "minzoom": 6.0,
      "layout": { "line-cap": "butt", "line-join": "round", "visibility": "none" },
      "paint": {
        "line-color": { "stops": [[8, "hsla(0, 0%, 100%, 0.2)"], [14, "hsla(0, 0%, 100%, 0.4)"], [18, "hsla(0, 0%, 100%, 0.5)"]] },
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, ["match", ["get", "class"], ["motorway", "motorway_link"], 1, 0], 7, ["match", ["get", "class"], ["motorway", "motorway_link", "trunk"], 1.4, 0], 8, ["match", ["get", "class"], ["motorway", "motorway_link", "primary", "trunk"], 0.75, 0], 9, ["match", ["get", "class"], ["secondary", "tertiary"], 0.7, 1], 10, ["match", ["get", "class"], ["motorway", "motorway_link"], 1.3, 1.3], 14, ["match", ["get", "class"], ["minor", "service"], 0.5, 2.4]]
      },
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["match", ["get", "brunnel"], ["tunnel"], false, true], ["any", ["==", ["get", "construction"], false], ["!", ["has", "construction"]]]]
    },
    {
      "id": "Railway",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "railway",
      "minzoom": 11.0,
      "layout": { "visibility": "none" },
      "paint": {
        "line-color": "hsla(34, 0%, 100%, 0.2)",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 11, 0.5, 16, 1.3],
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1, 16, 2]
      },
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["any", ["==", ["get", "construction"], false], ["!", ["has", "construction"]]]]
    },
    {
      "id": "Country border",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "country_border",
      "layout": { "line-cap": "round", "line-join": "round", "visibility": "none" },
      "paint": {
        "line-color": "hsl(0, 0%, 94%)",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 3, 0.5, 9, 1.5, 22, 32]
      },
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["any", ["==", ["get", "maritime"], false], ["!", ["has", "maritime"]]]]
    },
    {
      "id": "Road labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "road_label",
      "minzoom": 11.0,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Medium"],
        "text-letter-spacing": 0.1,
        "text-rotation-alignment": "map",
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 8, 16, 11, 22, 16],
        "visibility": "none"
      },
      "paint": { "text-color": "hsl(0, 0%, 100%)", "text-halo-color": "hsl(0, 0%, 17%)", "text-halo-width": 1 },
      "filter": ["all", ["==", ["geometry-type"], "LineString"], ["any", ["==", ["get", "construction"], false], ["!", ["has", "construction"]]]]
    },
    {
      "id": "Place labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "place_label",
      "minzoom": 10.0,
      "maxzoom": 16.0,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 12, 14, 13],
        "visibility": "none"
      },
      "paint": { "text-color": "hsl(0, 0%, 100%)", "text-halo-color": "hsl(0, 0%, 0%)", "text-halo-width": 1 }
    },
    {
      "id": "Town labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "town_label",
      "minzoom": 9.0,
      "maxzoom": 16.0,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 6, 11, 8, 14, 10, 15],
        "visibility": "none"
      },
      "paint": { "text-color": "hsl(0, 0%, 100%)", "text-halo-color": "hsl(0, 0%, 0%)", "text-halo-width": 1 }
    },
    {
      "id": "City labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "city_label",
      "minzoom": 3.0,
      "maxzoom": 16.0,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Medium"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 11, 6, 13, 8, 16, 12, 18, 16, 20],
        "visibility": "none"
      },
      "paint": { "text-color": "hsl(0, 0%, 100%)", "text-halo-color": "hsl(0, 0%, 0%)", "text-halo-width": 1 }
    },
    {
      "id": "Country labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "country_label",
      "minzoom": 1.0,
      "maxzoom": 12.0,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear", 1], ["zoom"], 1, 12, 4, 14, 6, 18, 9, 22],
        "visibility": "none"
      },
      "paint": { "text-color": "hsl(0, 0%, 100%)", "text-halo-color": "hsl(0, 0%, 0%)", "text-halo-width": 1 }
    }
  ],
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={key}",
  "sprite": "https://api.maptiler.com/maps/basic-v2/sprite",
  "bearing": 0.0,
  "pitch": 0.0,
  "center": [0.0, 0.0],
  "zoom": 1.0
}
