{
  "version": 8,
  "name": "Tusche Poster",
  "sources": {
    "maptiler_planet": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key={key}"
    }
  },
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={key}",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#ffffff" }
    },
    {
      "id": "landcover-outline",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "landcover",
      "filter": ["in", "class", "wood", "grass", "farmland", "wetland", "sand"],
      "minzoom": 6,
      "paint": {
        "line-color": "#d4d4d4",
        "line-width": { "stops": [[6, 0.2], [10, 0.35], [13, 0.5], [16, 0.7]] }
      }
    },
    {
      "id": "landuse-outline",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "landuse",
      "filter": ["in", "class", "residential", "industrial", "commercial", "retail", "cemetery", "school", "pitch"],
      "minzoom": 8,
      "paint": {
        "line-color": "#cfcfcf",
        "line-width": { "stops": [[8, 0.2], [11, 0.35], [14, 0.55], [16, 0.8]] }
      }
    },
    {
      "id": "park-outline",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "park",
      "minzoom": 7,
      "paint": {
        "line-color": "#c8c8c8",
        "line-width": { "stops": [[7, 0.25], [11, 0.4], [14, 0.6], [16, 0.9]] }
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "water",
      "paint": { "fill-color": "#111111" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#111111",
        "line-width": { "stops": [[5, 0.4], [10, 1.0], [14, 2.2], [16, 3.0]] }
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "boundary",
      "filter": ["<=", "admin_level", 6],
      "minzoom": 5,
      "paint": {
        "line-color": "#bdbdbd",
        "line-width": { "stops": [[5, 0.3], [10, 0.5], [14, 0.8]] },
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "roads-path",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "minzoom": 9,
      "paint": {
        "line-color": "#b8b8b8",
        "line-width": { "stops": [[9, 0.25], [12, 0.5], [14, 0.7], [16, 1.0]] }
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "residential"],
      "paint": {
        "line-color": "#9e9e9e",
        "line-width": { "stops": [[6, 0.25], [8, 0.5], [10, 0.8], [12, 1.1], [14, 1.5], [16, 2.0]] }
      }
    },
    {
      "id": "roads-secondary",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "paint": {
        "line-color": "#4a4a4a",
        "line-width": { "stops": [[5, 0.5], [8, 1.0], [11, 1.6], [13, 2.2], [15, 2.8], [17, 3.6]] }
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk", "motorway"],
      "paint": {
        "line-color": "#0c0c0c",
        "line-width": { "stops": [[4, 0.7], [6, 1.2], [8, 2.0], [10, 2.8], [12, 3.6], [14, 4.6], [16, 6.0]] }
      }
    },
    {
      "id": "rail",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "minzoom": 10,
      "paint": {
        "line-color": "#1a1a1a",
        "line-width": { "stops": [[10, 0.3], [14, 0.7], [16, 1.0]] },
        "line-dasharray": [3, 2]
      }
    }
  ]
}
