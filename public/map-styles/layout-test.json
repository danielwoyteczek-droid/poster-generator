{
  "version": 8,
  "name": "Minimal Poster World",
  "sources": {
    "maptiler_planet": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key={key}"
    }
  },
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={key}",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f8f8f6" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "water",
      "paint": { "fill-color": "#c7dbef" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#c7dbef",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.5, 10, 1.2, 14, 2.5]
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "residential"],
      "paint": {
        "fill-color": "#111111",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0.08, 8, 0.14, 11, 0.18, 13, 0.08]
      }
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "landuse",
      "filter": ["in", ["get", "class"], ["literal", ["industrial", "commercial", "retail"]]],
      "paint": {
        "fill-color": "#111111",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0.10, 8, 0.16, 11, 0.22, 13, 0.12]
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "park",
      "paint": { "fill-color": "#f3f3f0", "fill-opacity": 1 }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["minor", "service", "track"]]],
      "paint": {
        "line-color": "#efefec",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.3, 14, 0.8, 16, 1.2],
        "line-opacity": 0.35
      }
    },
    {
      "id": "roads-main",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["primary", "secondary", "tertiary", "trunk"]]],
      "paint": {
        "line-color": "#ecebe7",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.4, 10, 0.8, 14, 1.8, 16, 2.8],
        "line-opacity": 0.45
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "building",
      "minzoom": 11,
      "paint": {
        "fill-color": "#111111",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          11, 0.08,
          12, 0.16,
          13, 0.32,
          14, 0.55,
          16, 0.85
        ]
      }
    },
    {
      "id": "building-outline",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "building",
      "minzoom": 12,
      "paint": {
        "line-color": "#111111",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.15,
          14, 0.35,
          16, 0.6
        ],
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.10,
          13, 0.18,
          14, 0.28,
          16, 0.4
        ]
      }
    }
  ]
}
