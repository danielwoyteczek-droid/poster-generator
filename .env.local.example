# MapTiler (required)
NEXT_PUBLIC_MAPTILER_API_KEY=your_maptiler_public_key_here
MAPTILER_API_KEY=your_maptiler_secret_key_here

# Supabase (required for auth + project saving - PROJ-4 / PROJ-5)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_key_here

# Stripe (required for payments - PROJ-6)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (required for order confirmation emails - PROJ-6)
RESEND_API_KEY=re_...

# Admin notifications (optional - PROJ-10)
ADMIN_EMAIL=admin@example.com

# App URL used in emails when webhook cannot detect origin (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sanity CMS (required for Blog, About, Legal, FAQ - PROJ-13)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Google Tag Manager (optional - loads GA4, Meta/TikTok pixels once configured)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Blog Automation (PROJ-14 - required only to run scripts in scripts/blog-automation/)
ANTHROPIC_API_KEY=sk-ant-...
SANITY_API_WRITE_TOKEN=your_sanity_write_token_here
BLOG_AUTOMATION_MONTHLY_BUDGET_USD=5
BLOG_AUTOMATION_MODEL=claude-opus-4-7

# Sentry Error Tracking (optional but recommended for production)
# Holen aus sentry.io: Settings → Projects → [project] → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://abc123@o0.ingest.sentry.io/1234567
# Server-side fällt auf NEXT_PUBLIC_SENTRY_DSN zurück, falls SENTRY_DSN leer.
SENTRY_DSN=
# Source-map-Upload während Vercel-Builds (Stacktraces unminifizieren).
# Auth-Token: sentry.io → Settings → Auth Tokens → "project:releases" + "project:read" Scopes
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=petite-moment
SENTRY_AUTH_TOKEN=sntrys_xxx
# Set to "true" to enable Sentry in local dev (default: prod-only).
NEXT_PUBLIC_SENTRY_ENABLED=
SENTRY_ENABLED=

# Preset-Render-Pipeline (PROJ-30) — Dynamic Mockups (PSD-Smart-Object-Replacement)
# Holen aus dynamicmockups.com → API Dashboard → API Key
DYNAMIC_MOCKUPS_API_KEY=your_dynamic_mockups_api_key_here
DYNAMIC_MOCKUPS_API_URL=https://app.dynamicmockups.com/api/v1
# Timeout für Sync-API (Dynamic Mockups antwortet typisch in 5-15s)
DYNAMIC_MOCKUPS_TIMEOUT_MS=60000

# Preset-Render-Pipeline (PROJ-30) — Headless-Editor-Modus
# Geheimer Token, mit dem der Worker den Editor im Headless-Modus aufruft.
# Mind. 32 Zeichen, am einfachsten: openssl rand -hex 32
RENDER_HEADLESS_TOKEN=your_random_secret_min_32_chars

# Preset-Render-Pipeline (PROJ-30) — Worker-Konfiguration
# Base-URL der App, gegen die der Worker rendert (lokal vs. staging vs. production)
APP_BASE_URL=http://localhost:3000
# Anzahl paralleler Playwright-Browser pro Worker (Default 1, max 4)
RENDER_PARALLEL_BROWSERS=1
# Timeout pro Render-Job in ms (Default 60000)
RENDER_BROWSER_TIMEOUT_MS=60000
# Polling-Intervall des Workers gegen die DB in ms (Default 5000)
RENDER_POLL_INTERVAL_MS=5000

# Preset-Render-Pipeline (PROJ-30) — "Worker starten"-Button im Admin
# Erlaubt dem Admin-UI, den GitHub-Actions-Workflow per Klick zu triggern,
# ohne den Tab zu wechseln und sich auf github.com einzuloggen.
# Token: github.com → Settings → Developer settings → Personal access tokens
#   → Fine-grained tokens → Generate new token
#   → Repository access: nur dieses Repo
#   → Permissions → Repository permissions → Actions: Read and write
GITHUB_WORKFLOW_TRIGGER_TOKEN=github_pat_...
# Repo im Format owner/repo (z. B. danielwoyteczek-droid/poster-generator)
GITHUB_REPO=owner/repo

# Etsy-Integration (PROJ-49) — Listing-Sync + Bestellungs-Importer
# Setup-Schritte:
#   1. Etsy-Developer-Account: https://www.etsy.com/developers/your-apps
#      → "Create a new app"
#   2. Aus der App-Detailseite kopieren:
#      → Keystring        → ETSY_OAUTH_CLIENT_ID
#      → Shared Secret    → ETSY_OAUTH_CLIENT_SECRET
#   3. Redirect-URI in der Etsy-App-Config eintragen:
#      Production: https://petite-moment.com/api/etsy/oauth/callback
#      Lokal:      http://localhost:3000/api/etsy/oauth/callback
#   4. Scopes ankreuzen: listings_r listings_w listings_d transactions_r
#      transactions_w shops_r address_r
#   5. OAuth-Setup einmalig durchlaufen: /private/admin/etsy/oauth
#      → der Flow speichert den Refresh-Token in der DB,
#        ETSY_OAUTH_CLIENT_SECRET wird nicht zur Laufzeit gebraucht.
ETSY_OAUTH_CLIENT_ID=
ETSY_OAUTH_CLIENT_SECRET=
# Optional: Redirect-URI hardcoden. Wenn leer, wird sie aus der Request-Origin
# abgeleitet — das funktioniert sowohl lokal als auch in production.
ETSY_OAUTH_REDIRECT_URI=

# Shared Secret für den GitHub-Actions-Cronjob → API-Route /api/etsy/cron/pull-orders.
# Mind. 32 Zeichen, am einfachsten: openssl rand -hex 32
# In production zusätzlich als GitHub-Actions-Secret hinterlegen.
ETSY_CRON_SECRET=

# B2B Credits-Abo (PROJ-50) — Subscription-Tier-Price-IDs.
# Setup-Schritte:
#   1. Stripe-Dashboard → Products → "Add product" für jeden Tier:
#      - Petite-Moment B2B Starter (recurring monthly)
#      - Petite-Moment B2B Pro (recurring monthly)
#      - Petite-Moment B2B Business (recurring monthly)
#   2. Pro Product: Prices in EUR, USD, GBP anlegen (3 Prices pro Product).
#   3. Price-IDs hier eintragen (Format: price_1AbCd...).
#   4. Stripe Tax aktivieren: Settings → Tax → Enable Stripe Tax.
#   5. Customer Portal aktivieren: Settings → Billing → Customer Portal.
#      Erlauben: Plan-Wechsel, Karten-Update, Kündigung.
# Leere Werte = Tier ist nicht konfiguriert. Checkout-Calls für leere Tiers
# liefern 503 Service Unavailable mit klarer Fehlermeldung.
STRIPE_PRICE_B2B_STARTER_EUR=
STRIPE_PRICE_B2B_STARTER_USD=
STRIPE_PRICE_B2B_STARTER_GBP=
STRIPE_PRICE_B2B_PRO_EUR=
STRIPE_PRICE_B2B_PRO_USD=
STRIPE_PRICE_B2B_PRO_GBP=
STRIPE_PRICE_B2B_BUSINESS_EUR=
STRIPE_PRICE_B2B_BUSINESS_USD=
STRIPE_PRICE_B2B_BUSINESS_GBP=

# B2B Overage-Metered-Prices (PROJ-50). Initial: 20 Cent pro zusätzlichem
# Projekt-Export über das Tier-Limit. In Stripe als "Metered" recurring price
# anlegen mit billing_scheme=per_unit. Ein eigenes Product ("B2B Overage")
# mit 3 Prices (EUR/USD/GBP), alle metered, alle 20 Cent.
STRIPE_PRICE_B2B_OVERAGE_EUR=
STRIPE_PRICE_B2B_OVERAGE_USD=
STRIPE_PRICE_B2B_OVERAGE_GBP=
